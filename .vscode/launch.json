{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "coreclr",
            "request": "launch",
            "name": ".NET Backend (localhost:5000)",
            "program": "${workspaceFolder}/HighlyZensitive.Server/bin/Debug/net8.0/HighlyZensitive.Server.dll",
            "args": [],
            "cwd": "${workspaceFolder}/HighlyZensitive.Server",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Now listening on: (https?://\\S+)",
                "uriFormat": "http://localhost:5000"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "launchBrowser": {
                "enabled": true,
                "args": "http://localhost:5000"
            },
            "console": "internalConsole"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Angular Client (localhost:4200)",
            "url": "http://localhost:4200",
            "webRoot": "${workspaceFolder}/highlyzensitive.client/src"
        }
    ],
    "compounds": [
        {
            "name": "Debug All (Backend & Client)",
            "configurations": [
                ".NET Backend (localhost:5000)",
                "Angular Client (localhost:4200)"
            ]
        }
    ]
}